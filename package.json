{
  "name": "who-am-eee",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun dist/src/main.js",
    "dev": "bun --hot run index.ts",
    "build": "bun run build.config.ts && cp -r ./public/. ./dist/",
    "build:prod": "NODE_ENV=production bun run build.config.ts && cp -r ./public/. ./dist/",
    "serve": "bun run build && bun run start",
    "serve:prod": "bun run build:prod && bun server.prod.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "rolldown": "^1.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "figlet": "^1.11.0",
    "lenis": "^1.3.23"
  }
}
